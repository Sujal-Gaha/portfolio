---
import { type CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'

type Props = {
  experiment: CollectionEntry<'experiments'>
}

const { experiment } = Astro.props
const { title, description, date, category, image } = experiment.data
---

<a
  href={`/experiments/${experiment.slug}`}
  class="group relative flex flex-col overflow-hidden rounded-xl border bg-background transition-all duration-300 ease-in-out hover:border-primary/50 hover:shadow-lg"
>
  {
    image && (
      <div class="relative h-48 w-full overflow-hidden border-b">
        <Image
          src={image}
          alt={title}
          width={600}
          height={300}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
        {category && (
          <div class="absolute right-2 top-2 rounded-md bg-background/80 px-2 py-1 text-[10px] font-bold uppercase tracking-wider backdrop-blur-sm border">
            {category}
          </div>
        )}
      </div>
    )
  }

  <div class="flex flex-grow flex-col p-4">
    <div class="mb-2 flex items-center justify-between">
      <span class="text-xs text-muted-foreground font-mono">
        <!-- {formatDate(date)} -->
      </span>
      <Icon name="lucide:flask-conical" class="size-4 text-muted-foreground group-hover:text-primary transition-colors" />
    </div>
    
    <h3 class="mb-2 text-lg font-bold leading-tight group-hover:text-primary transition-colors">
      {title}
    </h3>
    
    <p class="line-clamp-2 text-sm text-muted-foreground">
      {description}
    </p>
    
    <div class="mt-4 flex items-center text-xs font-medium text-primary opacity-0 transition-opacity group-hover:opacity-100">
      View Experiment <Icon name="lucide:arrow-right" class="ml-1 size-3" />
    </div>
  </div>
</a>
