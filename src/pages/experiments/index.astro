---
import { getCollection } from 'astro:content'
import Layout from '@/layouts/Layout.astro'
import Container from '@/components/Container.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import ExperimentCard from '@/components/ExperimentCard.astro'

const experiments = (await getCollection('experiments'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<Layout 
  title="The Lab | Experiments" 
  description="Technical experiments with 3D rendering, animations, and frontend logic."
>
  <Container class="flex flex-col gap-y-8">
    <Breadcrumbs items={[{ label: 'Experiments', icon: 'lucide:flask-conical' }]} />
    
    <header class="flex flex-col gap-y-2">
      <h1 class="text-4xl font-bold tracking-tight">The Lab</h1>
      <p class="text-muted-foreground text-lg max-w-2xl">
        A dedicated space for technical experiments, 3D scenes with Three.js, and interactive web components.
      </p>
    </header>

    {
      experiments.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {experiments.map((experiment) => (
            <ExperimentCard experiment={experiment} />
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20 border rounded-xl border-dashed">
          <p class="text-muted-foreground italic">No experiments found. Check back later!</p>
        </div>
      )
    }
  </Container>
</Layout>
