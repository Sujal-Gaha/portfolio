---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Container from '@/components/Container.astro'
import ExperimentCard from '@/components/ExperimentCard.astro'
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'

const experiments = (await getCollection('experiments')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
---

<Layout
  title="The Lab | Experiments"
  description="Technical experiments with 3D rendering, animations, and frontend logic."
>
  <Container class="flex flex-col gap-y-8">
    <Breadcrumbs
      items={[{ label: 'Experiments', icon: 'lucide:flask-conical' }]}
    />

    <header class="flex flex-col gap-y-2">
      <h1 class="text-4xl font-bold tracking-tight">The Lab</h1>
      <p class="max-w-2xl text-lg text-muted-foreground">
        A dedicated space for technical experiments, 3D scenes with Three.js,
        and interactive web components.
      </p>
    </header>

    {
      experiments.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {experiments.map((experiment) => (
            <ExperimentCard experiment={experiment} />
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center rounded-xl border border-dashed py-20">
          <p class="italic text-muted-foreground">
            No experiments found. Check back later!
          </p>
        </div>
      )
    }
  </Container>
</Layout>
